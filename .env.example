# Required for real chat replies from OpenAI Responses API
# If missing, chat requests return a visible error: OPENAI_API_KEY is not configured.
OPENAI_API_KEY=

# Optional fallback model (used before settings are saved)
OPENAI_MODEL=gpt-4o-mini

# Optional fallback system prompt (used before settings are saved)
OPENAI_SYSTEM_PROMPT=You are Studio Assistant Agent. Provide clear and concise answers.

# SQLite path for Prisma
DATABASE_URL="file:./dev.db"
