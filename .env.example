# OpenAI API key for chat agent
OPENAI_API_KEY=

# Responses API model (default fallback in code: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Optional system prompt override
OPENAI_SYSTEM_PROMPT=You are Studio Assistant Agent. Provide clear and concise answers.

# SQLite path for Prisma
DATABASE_URL="file:./dev.db"
